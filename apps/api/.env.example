# ============================================
# PRIMO API - Environment Variables (EXAMPLE)
# ============================================
# Copy to `.env` and fill in real values.
# This file IS tracked in git — never put real credentials here.

# Server
NODE_ENV=development
PORT=5005
API_VERSION=v1

# MongoDB
# Local: mongodb://localhost:27017/primo
# Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/primo?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/primo

# JWT — REQUIRED, no fallback. Generate strong unique values with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=PRIMO <noreply@primo.com>
COMPANY_EMAIL=contact@primo.com

# Web Push (Generate with web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:contact@primo.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Payment gateway (PSP)
# Leave PAYMENT_PROVIDER unset (or 'none') to run cash-on-delivery only.
# Set to 'moyasar' for a Saudi PSP supporting mada, Apple Pay and cards.
# These are SECRETS — keep them in .env, never in the database or settings UI.
PAYMENT_PROVIDER=none
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend URL (for emails and redirects)
FRONTEND_URL=http://localhost:3000
